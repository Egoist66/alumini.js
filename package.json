{
  "name": "alumini",
  "packageManager": "yarn@1.22.22",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./demo/src/lib/alumini.js",
  "module": "./demo/src/lib/alumini.js",
  "types": "./demo/src/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./demo/src/lib/alumini.js",
      "types": "./demo/src/lib/index.d.ts"
    }
  },
  "files": [
    "demo/src/lib"
  ],
  "scripts": {
    "clean": "rimraf demo/src/lib",
    "build:js": "vite build",
    "build:types": "tsc --emitDeclarationOnly --declarationDir demo/src/lib/types && dts-bundle-generator -o demo/src/lib/index.d.ts demo/src/lib/types/index.d.ts && rimraf demo/src/lib/types",
    "build:docs": "node scripts/generate-docs.mjs",
    "build": "yarn clean && yarn build:js && yarn build:types && yarn build:docs",
    "dev": "vite",
    "preview": "vite preview"
  },
  "devDependencies": {
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-dts": "^6.4.1",
    "terser": "^5.43.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
